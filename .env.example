# Database Configuration
DATABASE_URL=ecto://postgres:postgres@localhost/dialekt_dev
POOL_SIZE=10

# Phoenix Configuration
SECRET_KEY_BASE=generate_with_mix_phx_gen_secret
PHX_HOST=localhost
PORT=4000
PHX_SERVER=true

# DNS Cluster (optional)
DNS_CLUSTER_QUERY=

# LLM Model Configuration
AI_PROVIDER=openai # anthropic, openai, or openrouter
AI_MODEL=gpt-5-nano-2025-08-07 # model id for the provider. 
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Environment
MIX_ENV=dev
