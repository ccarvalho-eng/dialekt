# Database Configuration
DATABASE_URL=ecto://postgres:postgres@localhost/dialekt_dev
POOL_SIZE=10

# Phoenix Configuration
SECRET_KEY_BASE=generate_with_mix_phx_gen_secret
PHX_HOST=localhost
PORT=4000
PHX_SERVER=true

# DNS Cluster (optional)
DNS_CLUSTER_QUERY=

# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Environment
MIX_ENV=dev
